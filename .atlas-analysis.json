  "keyFeatures": [
    "Modular crate architecture with strict tier system",
    "Multiple video codec support (RemoteFX, RLE, RDP 6.0)",
    "Static and dynamic virtual channels",
    "Client and server implementations",
    "Security-focused design with fuzzing",
    "Cross-platform no_std compatibility",
    "FFI bindings for C/C# and WebAssembly support",
    "Async and blocking I/O abstractions"
  ],
  "publicApiSurface": [
    "ironrdp - Meta crate re-exporting core functionality",
    "ironrdp-core - Common traits (Encode, Decode, ReadCursor, WriteCursor)",
    "ironrdp-pdu - PDU encoding/decoding for RDP protocol",
    "ironrdp-graphics - Image processing and codec implementations",
    "ironrdp-connector - RDP connection state machines",
    "ironrdp-session - RDP session state machines",
    "ironrdp-svc - Static virtual channel traits",
    "ironrdp-dvc - Dynamic virtual channel implementation",
    "ironrdp-cliprdr - CLIPRDR clipboard channel",
    "ironrdp-rdpdr - RDPDR device redirection channel",
    "ironrdp-rdpsnd - RDPSND audio output channel",
    "ironrdp-input - Input packet utilities",
    "ironrdp-blocking - Blocking I/O abstraction",
    "ironrdp-async - Async Future wrappers",
    "ironrdp-tokio - Tokio integration",
    "ironrdp-futures - Futures integration",
    "ironrdp-client - Portable RDP client",
    "ironrdp-acceptor - Connection acceptance state machines",
    "ironrdp-server - Extendable RDP server skeleton",
    "ironrdp-web - WebAssembly bindings"
  ]
}
